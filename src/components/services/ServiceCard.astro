---
interface Props {
  number: string;
  title: string;
  description: string;
  items: string[];
  tags: string[];
}

const { number, title, description, items, tags } = Astro.props;
---

<div class="reveal border border-border p-8 md:p-10 hover:border-accent transition-colors duration-150 group">
  <div class="flex items-start justify-between mb-6">
    <span class="font-mono text-2xs text-accent">{number}</span>
    <div class="flex flex-wrap gap-1.5 justify-end">
      {tags.map((tag) => (
        <span class="font-mono text-2xs text-ink-3 border border-border px-2 py-1">
          {tag}
        </span>
      ))}
    </div>
  </div>

  <h3 class="font-display font-semibold text-2xl md:text-3xl text-ink mb-4 leading-tight">
    {title}
  </h3>

  <p class="text-sm text-ink-2 leading-relaxed mb-8">
    {description}
  </p>

  <ul class="space-y-2.5">
    {items.map((item) => (
      <li class="flex items-start gap-3 text-sm text-ink-2">
        <span class="text-accent shrink-0 font-mono mt-0.5">—</span>
        <span>{item}</span>
      </li>
    ))}
  </ul>
</div>
