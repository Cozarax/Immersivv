---
import Container from '@/components/ui/Container.astro';
---

<section class="py-28 bg-bg-2">
  <Container>
    <div class="reveal text-center max-w-[560px] mx-auto">
      <h2 class="font-display font-semibold text-4xl md:text-5xl text-ink leading-tight mb-6">
        Vous avez un projet ?
      </h2>
      <p class="text-base text-ink-2 leading-relaxed mb-10">
        Je suis disponible pour des missions freelance. Si votre projet vous tient à cœur,
        il mérite une exécution soignée.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-3 font-sans font-medium text-sm bg-accent text-bg px-8 py-4 hover:opacity-90 transition-opacity duration-150"
      >
        Prendre contact
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </Container>
</section>
