---
import Container from '@/components/ui/Container.astro';
import SectionLabel from '@/components/ui/SectionLabel.astro';

const values = [
  {
    title: 'Code orienté produit',
    description:
      'Je ne code pas pour coder. Chaque décision technique est prise en fonction des objectifs business et de l\'expérience utilisateur finale.',
  },
  {
    title: 'Design & développement, ensemble',
    description:
      'Ma sensibilité design me permet de travailler en autonomie sur l\'interface ou en collaboration étroite avec un designer.',
  },
  {
    title: 'Performance & maintenabilité',
    description:
      'Des interfaces rapides, un code lisible, une architecture pensée pour durer — pas juste pour livrer.',
  },
];
---

<section class="py-28">
  <Container>
    <div class="reveal">
      <SectionLabel number="01" label="Proposition de valeur" class="mb-16" />
    </div>

    <div class="grid md:grid-cols-2 gap-16 items-start">
      <!-- Left: big statement -->
      <div class="reveal">
        <h2 class="font-display font-normal text-4xl md:text-5xl text-ink leading-[1.15]">
          Un développeur qui pense<br />
          <em class="text-accent ">par l'interface.</em>
        </h2>
      </div>

      <!-- Right: value pillars -->
      <div class="flex flex-col gap-10">
        {values.map((value, i) => (
          <div class="reveal" style={`transition-delay: ${i * 0.1}s`}>
            <div class="flex gap-5 items-start">
              <span class="font-mono text-2xs text-accent mt-1 shrink-0">
                {String(i + 1).padStart(2, '0')}
              </span>
              <div>
                <h3 class="font-sans text-sm font-medium text-ink mb-2">
                  {value.title}
                </h3>
                <p class="text-sm text-ink-2 leading-relaxed">
                  {value.description}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Container>
</section>

<div class="max-w-[1200px] mx-auto px-6 md:px-10">
  <div class="rule"></div>
</div>
