---
import Container from '@/components/ui/Container.astro';
import SectionLabel from '@/components/ui/SectionLabel.astro';

const skills = [
  'React',
  'TypeScript',
  'Node.js',
  'Next.js',
  'Tailwind CSS',
  'Astro',
  'REST / GraphQL',
  'Git',
];
---

<section class="py-28">
  <Container>
    <div class="reveal mb-16">
      <SectionLabel number="04" label="À propos" class="mb-6" />
    </div>

    <div class="grid md:grid-cols-2 gap-16 items-start">
      <!-- Text -->
      <div class="reveal">
        <h2 class="font-display font-semibold text-3xl md:text-4xl text-ink leading-tight mb-8">
          Je construis des interfaces avec intention.
        </h2>
        <div class="space-y-4 text-sm text-ink-2 leading-relaxed">
          <p>
            Je suis développeur freelance spécialisé en React et TypeScript, avec une forte
            sensibilité pour le design d'interface et l'expérience utilisateur. Ce qui m'intéresse,
            c'est l'endroit où la technique et l'expérience humaine se rencontrent.
          </p>
          <p>
            Je travaille avec des indépendants, des startups et des studios qui ont besoin d'un
            développeur capable de prendre une interface au sérieux — pas seulement de la coder.
          </p>
        </div>
        <div class="mt-10">
          <a
            href="/a-propos"
            class="inline-flex items-center gap-2 font-mono text-2xs uppercase tracking-widest text-ink-2 hover:text-accent transition-colors duration-150"
          >
            En savoir plus
            <svg width="14" height="10" viewBox="0 0 14 10" fill="none">
              <path d="M1 5h12M8 1l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Skills list -->
      <div class="reveal">
        <div class="border border-border p-8">
          <p class="section-label mb-8">Stack principale</p>
          <ul class="space-y-3">
            {skills.map((skill) => (
              <li class="flex items-center gap-3 text-sm text-ink-2">
                <span class="text-accent shrink-0 font-mono text-xs">—</span>
                <span>{skill}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </Container>
</section>

<div class="max-w-[1200px] mx-auto px-6 md:px-10">
  <div class="border-t border-border"></div>
</div>
