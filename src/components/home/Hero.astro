---
import Container from '@/components/ui/Container.astro';
import Grainient from '@/components/ui/Grainient';
import TechTags from '@/components/ui/TechTags';
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden">
  <!-- Grainient background -->
  <div class="absolute inset-0 z-0">
    <Grainient
      client:only="react"
      color1="#000000"
      color2="#4E148C"
      color3="#9D8DF1"
      timeSpeed={0.25}
      colorBalance={0}
      warpStrength={1}
      warpFrequency={5}
      warpSpeed={2}
      warpAmplitude={50}
      blendAngle={0}
      blendSoftness={0.05}
      rotationAmount={500}
      noiseScale={2}
      grainAmount={0.1}
      grainScale={2}
      grainAnimated={false}
      contrast={1.5}
      gamma={1}
      saturation={1}
      centerX={0}
      centerY={0}
      zoom={0.9}
    />
  </div>

  <!-- Fondu bas -->
  <div class="absolute inset-x-0 bottom-0 h-40 z-[1]" style="background: linear-gradient(to bottom, transparent, var(--bg))"></div>

  <!-- Contenu -->
  <Container class="pt-32 pb-24 relative z-10">
    <div class="max-w-[860px]">
      <!-- Availability badge -->
      <div class="flex items-center gap-3 mb-10 fade-in" style="animation-delay: 0.1s">
        <span class="relative flex h-2 w-2 shrink-0">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
        </span>
        <span class="font-mono text-2xs uppercase tracking-widest text-ink-2">
          Disponible — missions freelance
        </span>
      </div>

      <!-- H1 -->
      <h1
        class="font-display font-semibold text-5xl md:text-7xl leading-[1.1] mb-8 fade-in"
        style="animation-delay: 0.2s"
      >
        Je conçois des interfaces web qui allient{' '}
        <span class="text-accent">design</span>,<span class="text-accent"> UX</span> et <span class="text-accent">conversion</span>.
      </h1>

      <!-- Subtitle -->
      <p
        class="text-base md:text-lg text-ink-2 leading-relaxed max-w-[560px] mb-12 fade-in"
        style="animation-delay: 0.35s"
      >
        Développeur freelance spécialisé en React, TypeScript et Node.js. J'aide les marques,
        studios et entreprises à créer des interfaces modernes, rapides et impactantes.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-start gap-4 mb-16 fade-in" style="animation-delay: 0.5s">
        <a
          href="/contact"
          class="inline-flex items-center gap-3 font-sans font-medium text-sm bg-accent text-bg px-6 py-3.5 hover:opacity-90 transition-opacity duration-150"
        >
          Parler de votre projet
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a
          href="/projets"
          class="inline-flex items-center gap-3 font-sans font-medium text-sm text-accent border border-accent px-6 py-3.5 hover:bg-accent hover:text-bg transition-all duration-150"
        >
          Voir mes projets
        </a>
      </div>

      <!-- Tech tags -->
      <div class="fade-in" style="animation-delay: 0.6s">
        <TechTags client:only="react" tags={['React', 'TypeScript', 'Node.js']} />
      </div>
    </div>
  </Container>
</section>

<!-- Bottom separator -->
<div class="max-w-[1200px] mx-auto px-6 md:px-10">
  <div class="border-t border-border"></div>
</div>
