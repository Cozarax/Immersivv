---
const year = new Date().getFullYear();
---

<footer class="border-t border-border mt-32">
  <div class="max-w-[1200px] mx-auto px-6 md:px-10 py-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
    <p class="font-mono text-xs text-ink-3">
      © {year} Axel — Tous droits réservés.
    </p>
    <nav class="flex items-center gap-6">
      <a
        href="https://linkedin.com/in/axel"
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-xs text-ink-3 hover:text-ink-2 transition-colors duration-150"
      >
        LinkedIn
      </a>
      <a
        href="https://github.com/axel"
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-xs text-ink-3 hover:text-ink-2 transition-colors duration-150"
      >
        GitHub
      </a>
      <a
        href="/contact"
        class="font-mono text-xs text-ink-3 hover:text-ink-2 transition-colors duration-150"
      >
        Contact
      </a>
    </nav>
  </div>
</footer>
