---
interface Props {
  title: string;
  description: string;
  type: string;
  year: number;
  stack: string[];
  liveUrl?: string;
  repoUrl?: string;
}

const { title, description, type, year, stack, liveUrl, repoUrl } = Astro.props;
---

<div class="py-20 border-b border-border">
  <div class="max-w-[1200px] mx-auto px-6 md:px-10">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 font-mono text-2xs uppercase tracking-widest text-ink-3 mb-12">
      <a href="/projets" class="hover:text-accent transition-colors duration-150">Projets</a>
      <span class="text-border-2">—</span>
      <span class="text-ink-2">{title}</span>
    </nav>

    <div class="grid md:grid-cols-3 gap-12">
      <!-- Title block -->
      <div class="md:col-span-2">
        <!-- Type badge -->
        <span class="inline-block font-mono text-2xs uppercase tracking-widest text-accent border border-accent/30 px-3 py-1 mb-6">
          {type}
        </span>
        <h1 class="font-display font-semibold text-4xl md:text-5xl lg:text-6xl text-ink leading-[1.1] mb-6">
          {title}
        </h1>
        <p class="text-base text-ink-2 leading-relaxed max-w-[520px]">
          {description}
        </p>
      </div>

      <!-- Meta block -->
      <div class="border border-border p-6 h-fit">
        <dl class="space-y-5">
          <div>
            <dt class="font-mono text-2xs uppercase tracking-widest text-ink-3 mb-1.5">Année</dt>
            <dd class="text-sm text-ink font-mono">{year}</dd>
          </div>
          <div class="border-t border-border pt-5">
            <dt class="font-mono text-2xs uppercase tracking-widest text-ink-3 mb-2">Stack</dt>
            <dd class="flex flex-wrap gap-1.5">
              {stack.map((tech) => (
                <span class="font-mono text-2xs text-ink-2 border border-border px-2 py-1">
                  {tech}
                </span>
              ))}
            </dd>
          </div>
          {(liveUrl || repoUrl) && (
            <div class="border-t border-border pt-5 flex flex-col gap-3">
              {liveUrl && (
                <a
                  href={liveUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 font-mono text-2xs uppercase tracking-widest text-accent hover:opacity-80 transition-opacity duration-150"
                >
                  Voir le site
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                    <path d="M1 9L9 1M9 1H4M9 1v5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              )}
              {repoUrl && (
                <a
                  href={repoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 font-mono text-2xs uppercase tracking-widest text-ink-2 hover:text-ink transition-colors duration-150"
                >
                  GitHub
                  <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                    <path d="M1 9L9 1M9 1H4M9 1v5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              )}
            </div>
          )}
        </dl>
      </div>
    </div>
  </div>
</div>
